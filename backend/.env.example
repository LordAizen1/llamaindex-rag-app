# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4.1-mini
EMBED_MODEL=text-embedding-3-large

# --- RAG params (defaults; the eval harness overrides these) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
MAX_TOKENS=512

# --- Storage ---
CHROMA_DIR=./storage/chroma
UPLOAD_DIR=./storage/uploads
COLLECTION_NAME=documents
SAMPLES_DIR=./samples
SEED_SAMPLES=true

# --- Rate limiting / cost backstop ---
# Leave the two Upstash vars blank to use the in-memory fallback (local dev).
# NOTE: the permanent per-IP query cap is only truly permanent with Upstash set;
# the in-memory fallback resets on restart and is per-replica.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PER_IP_QUERY_LIMIT=10          # PERMANENT lifetime cap per IP (no reset)
PER_IP_UPLOAD_HOURLY_LIMIT=20
GLOBAL_DAILY_LLM_CAP=500

# --- Uploads ---
MAX_UPLOAD_MB=20

# --- CORS: comma-separated origins, or * ---
CORS_ORIGINS=*
